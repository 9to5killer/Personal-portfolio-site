---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className = '' } = Astro.props;
const width = +(size * 138 / 80).toFixed(2);
---

<svg
  width={width}
  height={size}
  viewBox="0 0 138 80"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Kevin Clark"
  class={className}
>
  <title>Kevin Clark monogram</title>
  <rect x="0"   y="0"  width="22" height="80" rx="11"/>
  <rect x="36"  y="20" width="22" height="60" rx="11"/>
  <rect x="80"  y="0"  width="22" height="80" rx="11"/>
  <rect x="116" y="20" width="22" height="60" rx="11"/>
</svg>
