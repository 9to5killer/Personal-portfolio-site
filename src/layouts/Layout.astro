---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  darkHero?: boolean;
}
const {
  title       = 'Kevin Clark | AI Strategy & Deployment',
  description = 'Kevin Clark is a Director of AI Strategy and Deployment at a professional services firm, building internal agents, evaluation frameworks, and governance systems that make enterprise AI actually work.',
  darkHero    = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kevinclark.ai" />
    <link rel="canonical" href="https://kevinclark.ai" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="author" content="Kevin Clark" />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Kevin Clark",
      "url": "https://kevinclark.ai",
      "jobTitle": "Director, AI Strategy & Deployment",
      "description": "Building internal AI agents, evaluation frameworks, and governance systems for enterprise deployment.",
      "sameAs": [
        "https://www.linkedin.com/in/kevinfrancisclark/",
        "https://github.com/9to5killer"
      ]
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400&family=Inter:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style={darkHero ? 'background-color: #0A0E1A;' : ''}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div id="cursor-ring" aria-hidden="true"></div>
    <slot />

    <script is:inline>
      (function () {
        // Don't run on touch-only devices or reduced-motion
        if (
          !window.matchMedia('(hover: hover)').matches ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches
        ) return;

        const ring = document.getElementById('cursor-ring');
        if (!ring) return;

        document.body.classList.add('cursor-active');

        let mx = -100, my = -100, rx = -100, ry = -100;
        let raf;

        document.addEventListener('mousemove', (e) => {
          mx = e.clientX;
          my = e.clientY;
        });

        function lerp(a, b, t) { return a + (b - a) * t; }

        function tick() {
          rx = lerp(rx, mx, 0.4);
          ry = lerp(ry, my, 0.4);
          ring.style.left = rx + 'px';
          ring.style.top  = ry + 'px';
          raf = requestAnimationFrame(tick);
        }
        raf = requestAnimationFrame(tick);

        document.addEventListener('mouseover', (e) => {
          const el = e.target;
          const isLink = el.closest('a, button, [role="button"], [tabindex]');
          const isText = !isLink && el.closest('p, h1, h2, h3, h4, h5, li, blockquote, span');
          ring.classList.toggle('is-link', !!isLink);
          ring.classList.toggle('is-text', !!isText && !isLink);
        });

        document.addEventListener('mouseleave', () => {
          rx = ry = -100;
        });
      })();
    </script>

    <script>
      // Scroll-triggered fade-ups
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
          }
        }),
        { threshold: 0.07, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.fade-up').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
