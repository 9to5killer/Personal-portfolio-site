<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const $ = id => document.getElementById(id);
const sliders = [['rsiSlider','rsiVal',v=>v],['trailSlider','trailVal',v=>v+'%'],['holdSlider','holdVal',v=>v],['sizeSlider','sizeVal',v=>v+'%'],['coolSlider','coolVal',v=>v]];
sliders.forEach(([sid,vid,fmt])=>{const s=$(sid),v=$(vid);s.addEventListener('input',()=>{v.textContent=fmt(s.value);});});
const profiles={growth:{drift:0.0003,vol:0.018,trend:0.6},stable:{drift:0.0002,vol:0.010,trend:0.7},volatile:{drift:0.0002,vol:0.030,trend:0.45},sideways:{drift:0.00005,vol:0.012,trend:0.5}};
function generatePrice(bars,profile){const p=profiles[profile];const prices=[100];let trendDir=1,trendBars=0;for(let i=1;i<bars;i++){trendBars++;if(trendBars>20+Math.random()*40){trendDir=Math.random()<p.trend?1:-1;trendBars=0;}const ret=p.drift*trendDir+p.vol*(Math.random()*2-1);prices.push(Math.max(20,prices[i-1]*(1+ret)));}return prices;}
function computeRSI(prices,period){const rsi=new Array(prices.length).fill(null);if(prices.length<period+1)return rsi;let gains=0,losses=0;for(let i=1;i<=period;i++){const d=prices[i]-prices[i-1];if(d>0)gains+=d;else losses-=d;}let avgG=gains/period,avgL=losses/period;rsi[period]=100-100/(1+(avgL===0?100:avgG/avgL));for(let i=period+1;i<prices.length;i++){const d=prices[i]-prices[i-1];const g=d>0?d:0,l=d<0?-d:0;avgG=(avgG*(period-1)+g)/period;avgL=(avgL*(period-1)+l)/period;rsi[i]=100-100/(1+(avgL===0?100:avgG/avgL));}return rsi;}
function sma(arr,period){return arr.map((_,i)=>{if(i<period-1)return null;return arr.slice(i-period+1,i+1).reduce((a,b)=>a+b,0)/period;});}
let chartInstance=null;
function runSim(){
  const btn=$('runBtn');btn.disabled=true;btn.textContent='Running...';
  setTimeout(()=>{
    const profile=$('symbolSelect').value;
    const rsiOS=parseFloat($('rsiSlider').value);
    const trail=parseFloat($('trailSlider').value)/100;
    const minHold=parseInt($('holdSlider').value);
    const posPct=parseFloat($('sizeSlider').value)/100;
    const cooldown=parseInt($('coolSlider').value);
    const stopLoss=0.03;
    const BARS=Math.floor(365*6.5);
    const prices=generatePrice(BARS,profile);
    const rsiArr=computeRSI(prices,14);
    const sma9=sma(prices,9);const sma21=sma(prices,21);const sma50=sma(prices,50);
    let cash=100000,shares=0,entry=0,peak=0,barsHeld=0,barsExit=999,lastSL=false;
    const trades=[];const equity=[];
    for(let i=51;i<prices.length;i++){
      const price=prices[i];const rsi=rsiArr[i];
      const inTrend=price>sma50[i];
      const maCrossUp=sma9[i-1]!==null&&sma21[i-1]!==null&&sma9[i-1]<=sma21[i-1]&&sma9[i]>sma21[i];
      equity.push(cash+shares*price);
      if(shares>0){
        barsHeld++;if(price>peak)peak=price;
        if(price<=entry*(1-stopLoss)){const pnl=(price-entry)*shares;cash+=shares*price;trades.push({bar:i,action:'SELL',price,pnl,reason:'Stop loss'});shares=0;barsHeld=0;barsExit=0;lastSL=true;peak=0;continue;}
        if(barsHeld>=minHold&&price<=peak*(1-trail)){const pnl=(price-entry)*shares;cash+=shares*price;trades.push({bar:i,action:'SELL',price,pnl,reason:'Trail stop'});shares=0;barsHeld=0;barsExit=0;lastSL=false;peak=0;continue;}
        if(barsHeld>=minHold){const bearish=rsi>65||(sma9[i]<sma21[i]&&sma9[i-1]>=sma21[i-1]);if(bearish){const pnl=(price-entry)*shares;cash+=shares*price;trades.push({bar:i,action:'SELL',price,pnl,reason:'Signal'});shares=0;barsHeld=0;barsExit=0;lastSL=false;peak=0;}}
      } else {
        barsExit++;const cd=lastSL?barsExit:999;if(cd<cooldown)continue;if(!inTrend)continue;if(rsi===null)continue;
        if((rsi<rsiOS||maCrossUp)&&cash>0){const qty=Math.floor((cash*posPct)/price);if(qty>0){shares=qty;entry=price;peak=price;cash-=shares*price;barsHeld=0;trades.push({bar:i,action:'BUY',price,pnl:null,reason:rsi<rsiOS?'RSI dip':'MA cross'});}}
      }
    }
    if(shares>0){const price=prices[prices.length-1];const pnl=(price-entry)*shares;cash+=shares*price;trades.push({bar:prices.length-1,action:'SELL',price,pnl,reason:'End'});}
    const finalEquity=equity[equity.length-1]||100000;
    const ret=(finalEquity-100000)/100000*100;
    const sells=trades.filter(t=>t.action==='SELL'&&t.pnl!==null);
    const wins=sells.filter(t=>t.pnl>0);
    const winRate=sells.length>0?wins.length/sells.length*100:0;
    let peakEq=100000,maxDD=0;for(const e of equity){if(e>peakEq)peakEq=e;const dd=(peakEq-e)/peakEq*100;if(dd>maxDD)maxDD=dd;}
    const retEl=$('res-return');retEl.textContent=(ret>=0?'+':'')+ret.toFixed(1)+'%';retEl.className='result-value '+(ret>=0?'pos':'neg');
    $('res-trades').textContent=sells.length;
    $('res-winrate').textContent=winRate.toFixed(0)+'%';
    const ddEl=$('res-dd');ddEl.textContent='-'+maxDD.toFixed(1)+'%';ddEl.className='result-value '+(maxDD>10?'neg':'');
    const step=Math.max(1,Math.floor(equity.length/300));
    const chartData=equity.filter((_,i)=>i%step===0);
    if(chartInstance)chartInstance.destroy();
    chartInstance=new Chart($('equityChart'),{type:'line',data:{labels:chartData.map(()=>''),datasets:[{data:chartData,borderColor:ret>=0?'#60d080':'#f05060',borderWidth:1.5,fill:true,backgroundColor:ret>=0?'rgba(96,208,128,0.06)':'rgba(240,80,96,0.06)',pointRadius:0,tension:0.3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>'$'+Math.round(ctx.raw).toLocaleString()}}},scales:{x:{display:false},y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#555550',font:{family:'JetBrains Mono',size:10},callback:v=>'$'+Math.round(v/1000)+'k'}}}}});
    const logEl=$('tradeLog');const rowsEl=$('tradeRows');logEl.style.display='block';
    const recentTrades=trades.filter(t=>t.pnl!==null).slice(-30).reverse();
    rowsEl.innerHTML=recentTrades.map(t=>{const pnlStr=t.pnl!==null?(t.pnl>=0?'+$':'-$')+Math.abs(Math.round(t.pnl)).toLocaleString():'—';const pnlClass=t.pnl!==null?(t.pnl>=0?'pos':'neg'):'';return `<div class="trade-row ${t.action.toLowerCase()}"><span>${t.bar}</span><span class="action">${t.action}</span><span>$${t.price.toFixed(2)} <span style="color:var(--text-3);font-size:10px;">${t.reason}</span></span><span>—</span><span class="pnl ${pnlClass}">${pnlStr}</span></div>`;}).join('');
    btn.disabled=false;btn.textContent='Run Backtest — 365 days';
  },50);
}
</script>
</Layout>
